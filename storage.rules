rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Issue media: readable only by authenticated users (display uses tokenized
    // download URLs, which bypass rules, so viewing is unaffected). Writes are
    // limited to a signed-in user uploading a single bounded image/video.
    // Issue ownership can't be checked here — the issue is created in the DB
    // only after its media is uploaded — so the API enforces authorship.
    match /issues/{issueId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size <= 200 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    // Post media: same contract as issue media — the post is created in the DB
    // only after its media is uploaded, so the API enforces authorship.
    match /posts/{postId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size <= 200 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    // App assets: world-readable, written only via deploy/Admin SDK.
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
