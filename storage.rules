rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Issue media: world-readable; any signed-in user may write (issue
    // ownership is enforced by the API, not by Storage rules).
    match /issues/{issueId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // App assets: world-readable, written only via deploy/Admin SDK.
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
