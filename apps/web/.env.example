# tRPC endpoint — Firebase Functions URL.
# In production this points to the deployed Cloud Function exposing the tRPC handler.
# Falls back to a localhost emulator URL during development (see src/shared/config/env.ts).
VITE_API_URL=http://localhost:5001/raiymbek-park/us-central1/trpc

# Optional base path override for static hosting on GitHub Pages.
# Leave empty for "/" (Tauri / custom domain); set to "/<repo-name>/" for project Pages.
# VITE_BASE=/raiymbek-park/
