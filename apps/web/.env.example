# tRPC API base URL the web app calls (src/shared/config/env.ts).
#
# Unset (default): "/trpc" — a relative, same-origin path. In dev it is proxied
# to the local API by vite.config.ts (server.proxy -> http://localhost:3001),
# so LAN / device / tunnel (ngrok) testing and HTTPS work with no CORS and no
# mixed-content issues. No localhost-on-device footgun.
#
# Production: set this to the deployed API. Either keep "/trpc" and have your
# host/CDN proxy that path to the backend (same-origin), or use an absolute URL:
#   VITE_API_URL=https://api.example.com
# VITE_API_URL=/trpc

# Dev only: override where vite.config.ts proxies "/trpc" if the local API
# does not run on localhost:3001.
# VITE_DEV_API_TARGET=http://localhost:3001

# Optional base path override for static hosting on GitHub Pages.
# Leave empty for "/" (Tauri / custom domain); set to "/<repo-name>/" for project Pages.
# VITE_BASE=/raiymbek-park/

# Public VAPID key for FCM Web Push (Firebase console -> Cloud Messaging ->
# Web Push certificates). Unset: the app never obtains a push token and
# degrades to silence — no prompt, no error. Set as a repo Actions variable
# for the deployed build; CI does not check it.
# VITE_FCM_VAPID_KEY=
