# Local dev environment for the apps/api tRPC server.
# Copy this file to apps/api/.env and fill in the values; `npm run dev` loads it.

# Anthropic API key — required for on-demand comment translation.
# In production this is a Firebase Functions secret; the local dev server has no
# access to it, so provide your own key here to test comment translation.
ANTHROPIC_API_KEY=

# smsc.kz SMS gateway credentials — required for live OTP delivery (otp.send).
# In production these are Firebase Functions secrets (firebase functions:secrets:set).
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER=

# Set to `true` for local/e2e runs: otp.send honors the test-phone → fixed-code
# map (skips the smsc.kz call) instead of sending live SMS.
OTP_TEST_MODE=

# Optional: override the default tRPC port (3001).
# PORT=3001
