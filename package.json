{
  "name": "raiymbek-park",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "fallow": "fallow --format sarif",
    "format": "biome check --write .",
    "lint": "biome check .",
    "lint:fsd": "turbo run lint:fsd",
    "mutate": "turbo run mutate",
    "prepare": "git config core.hooksPath .githooks",
    "start": "clear && claude --dangerously-skip-permissions",
    "test": "vitest run",
    "test:e2e": "turbo run test:e2e",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "fallow": "2.99.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
